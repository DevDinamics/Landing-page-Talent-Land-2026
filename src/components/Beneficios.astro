---
/* src/components/Beneficios.astro */
import { GraduationCap, Coffee, Award, Users } from 'lucide-react';

const beneficios = [
  { icon: GraduationCap, title1: "Carrera y", title2: "Certificaciones", desc: "Planes claros para potenciar tus habilidades y acceso a capacitaciones oficiales en Google y Oracle." },
  { icon: Coffee, title1: "Flexibilidad", title2: "Híbrida", desc: "Lo mejor de los dos mundos. En Qualtop confiamos en tu talento, estés donde estés." },
  { icon: Award, title1: "Prestaciones", title2: "Superiores", desc: "Beneficios que realmente suman. Cuidamos de ti para que tú cuides de la innovación." },
  { icon: Users, title1: "Cultura", title2: "Colaborativa", desc: "Un equipo experto, joven y apasionado listo para mentorizarte en los retos más exigentes." }
];
---

<section id="section-beneficios" class="w-full py-32 px-6 bg-[#070708] text-white relative overflow-hidden group/section">
  
  <svg class="shape absolute top-[10%] left-[5%] w-12 h-12 text-[#E63B11] opacity-20 z-0 pointer-events-none" data-speed="0.2" data-mouse="0.05" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>
  <div class="shape absolute top-[25%] left-[15%] w-3 h-3 bg-white opacity-10 rounded-full z-0 pointer-events-none" data-speed="0.1" data-mouse="0.08"></div>
  <div class="shape absolute top-[60%] left-[8%] w-10 h-10 border border-[#E63B11]/20 rotate-12 z-0 pointer-events-none" data-speed="0.15" data-mouse="0.03"></div>
  <svg class="shape absolute bottom-[15%] left-[12%] w-16 h-16 text-white opacity-5 z-0 pointer-events-none" data-speed="-0.1" data-mouse="0.04" viewBox="0 0 100 100">
      <circle cx="20" cy="20" r="3" fill="currentColor"/><circle cx="50" cy="20" r="3" fill="currentColor"/><circle cx="20" cy="50" r="3" fill="currentColor"/><circle cx="50" cy="50" r="3" fill="currentColor"/>
  </svg>

  <div class="shape absolute top-[15%] right-[25%] w-5 h-5 border-2 border-white/10 rotate-45 z-0 pointer-events-none" data-speed="0.25" data-mouse="0.06"></div>
  <svg class="shape absolute top-[40%] right-[8%] w-14 h-14 text-[#E63B11] opacity-20 z-0 pointer-events-none" data-speed="0.12" data-mouse="0.04" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 12l18-9-9 18-9-9z"/></svg>
  <div class="shape absolute bottom-[30%] right-[20%] w-2 h-10 bg-[#E63B11] opacity-10 rotate-[35deg] z-0 pointer-events-none" data-speed="0.18" data-mouse="0.07"></div>
  <div class="shape absolute bottom-[10%] right-[40%] w-4 h-4 bg-white opacity-5 rotate-45 z-0 pointer-events-none" data-speed="0.08" data-mouse="0.09"></div>
  
  <svg class="shape absolute top-[70%] right-[15%] w-24 h-24 text-white opacity-10 z-0 pointer-events-none" data-speed="-0.05" data-mouse="0.02" viewBox="0 0 100 100">
      <rect x="10" y="10" width="4" height="4" fill="currentColor"/><rect x="30" y="10" width="4" height="4" fill="currentColor"/><rect x="50" y="10" width="4" height="4" fill="currentColor"/>
      <rect x="10" y="30" width="4" height="4" fill="currentColor"/><rect x="30" y="30" width="4" height="4" fill="currentColor"/><rect x="50" y="30" width="4" height="4" fill="currentColor"/>
  </svg>

  <div class="max-w-6xl mx-auto relative z-10">
    <div id="grid-beneficios" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {beneficios.map((item, index) => (
        <div class="beneficio-card opacity-0 translate-y-12 transition-all duration-700 ease-out group h-full" style={`transition-delay: ${index * 150}ms;`}>
          <div class="relative h-full bg-[#0b0b0b]/80 backdrop-blur-md rounded-3xl p-8 flex flex-col items-center text-center gap-6 border border-white/5 overflow-hidden transition-all duration-500 group-hover:border-[#E63B11]/40 group-hover:-translate-y-2">
            
            <div class="relative w-16 h-16 flex items-center justify-center border border-white/10 rounded-2xl bg-white/5 group-hover:border-[#E63B11]/50 group-hover:bg-[#E63B11]/10 transition-all duration-500">
              <item.icon className="w-8 h-8 text-gray-400 group-hover:text-[#E63B11] transition-colors" />
            </div>
            <h3 class="relative font-bold text-xl font-poppins tracking-tight uppercase leading-tight">
              {item.title1} <br/><span class="text-[#E63B11]">{item.title2}</span>
            </h3>
            <p class="relative text-sm text-gray-500 font-barlow leading-relaxed group-hover:text-gray-300 transition-colors duration-300">
              {item.desc}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const section = document.getElementById('section-beneficios');
    const shapes = document.querySelectorAll('.shape');
    
    let mouseX = 0;
    let mouseY = 0;

    window.addEventListener('mousemove', (e) => {
      mouseX = (e.clientX / window.innerWidth) - 0.5;
      mouseY = (e.clientY / window.innerHeight) - 0.5;
    });

    function animate() {
      if (!section) return; 
      
      const scrollY = window.scrollY;
      const sectionTop = section.offsetTop;
      const relativeScroll = scrollY - sectionTop;

      if (relativeScroll > -window.innerHeight && relativeScroll < section.offsetHeight) {
        shapes.forEach(shape => {
          const speed = parseFloat(shape.dataset.speed || 0);
          const mouseFactor = parseFloat(shape.dataset.mouse || 0);

          const ty = relativeScroll * speed;
          const mx = mouseX * 100 * mouseFactor;
          const my = mouseY * 100 * mouseFactor;

          const baseRotation = shape.style.transform.match(/rotate\(([^)]+)\)/)?.[0] || '';
          shape.style.transform = `translate(${mx}px, ${ty + my}px) ${baseRotation}`;
        });
      }
      requestAnimationFrame(animate);
    }

    requestAnimationFrame(animate);

    const cards = document.querySelectorAll('.beneficio-card');
    const cardsObserver = new IntersectionObserver((entries, obs) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.remove('opacity-0', 'translate-y-12');
          entry.target.classList.add('opacity-100', 'translate-y-0');
          obs.unobserve(entry.target);
        }
      });
    }, { 
      threshold: 0.1,
      rootMargin: "0px 0px -50px 0px" 
    });

    cards.forEach(card => cardsObserver.observe(card));
  })();
</script>