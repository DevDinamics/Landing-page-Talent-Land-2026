---
/* src/components/Crecimiento.astro */
import { Image } from 'astro:assets';
import atomoTech from '../assets/2-Secundario.png';
import logoTalent from '../assets/talend-land.png'; 
---

<section id="section-crecimiento" class="relative w-full py-20 md:py-32 px-6 overflow-hidden bg-[#070708] text-white">

  <div class="absolute inset-0 z-0 pointer-events-none">
    <div class="absolute top-[5%] left-[-15%] w-[300px] md:w-[600px] h-[300px] md:h-[600px] bg-[#E63B11] opacity-[0.06] blur-[80px] md:blur-[150px] rounded-full"></div>
    <div class="absolute bottom-[5%] right-[-10%] w-[300px] md:w-[500px] h-[300px] md:h-[500px] bg-green-500 opacity-[0.04] blur-[80px] md:blur-[130px] rounded-full"></div>

    <div class="watermark-1 absolute top-[5%] -left-10 md:-left-20 opacity-[0.05] md:opacity-10 w-[40%] md:w-[25%] h-auto grayscale brightness-200 rotate-[15deg]">
       <Image src={logoTalent} alt="Logo Talent Land" class="w-full h-auto" />
    </div>
    <div class="watermark-2 absolute bottom-[5%] -right-5 md:-right-10 opacity-[0.08] md:opacity-20 w-[50%] md:w-[30%] h-auto grayscale brightness-200 rotate-[-12deg]">
       <Image src={logoTalent} alt="Logo Talent Land" class="w-full h-auto" />
    </div>
  </div>

  <div class="max-w-6xl mx-auto relative z-10">
    
    <div class="text-center mb-16 md:mb-24 space-y-6">
      
      <div class="flex justify-center -mt-6 mb-8 md:-mt-16 md:mb-14 relative z-20">
        <div class="w-24 h-24 md:w-32 md:h-32 flex items-center justify-center backdrop-blur-xl shadow-inner  transition-all duration-500 group rounded-2xl">
          <Image 
            src={logoTalent} 
            alt="Icono Talent Land Central" 
            class="w-16 h-16 md:w-28 md:h-28 object-contain opacity-80 group-hover:opacity-100 group-hover:scale-110 transition-all duration-500"
          />
        </div>
      </div>

      <h2 class="text-3xl md:text-6xl font-black font-poppins tracking-tighter uppercase leading-[0.9] text-white drop-shadow-lg">
        El ecosistema donde <br/> vas a crear.
      </h2>

      <p class="text-gray-400 max-w-2xl mx-auto leading-relaxed text-base md:text-lg font-barlow">
        Proyectos reales, impacto global. Potenciamos tu capacidad en los sectores más dinámicos. En Qualtop aplicarás IA, Data y estrategias Multi-cloud para resolver retos críticos que mueven al mundo.
      </p>

      <div class="inline-block mt-4 md:mt-8">
        <div class="px-6 py-3 border border-green-500/20 bg-green-500/5 backdrop-blur-md text-[10px] md:text-sm font-medium text-green-400 tracking-wider">
          AQUÍ TU APRENDIZAJE NO TIENE TECHO Y TRABAJAS CODO A CODO CON TECNOLOGÍAS DE VANGUARDIA
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 md:gap-20 items-center scroll-reveal-container">
      
      <div class="space-y-6 md:space-y-10 scroll-element-up text-center lg:text-left order-2 lg:order-1">
        <h3 class="text-3xl md:text-5xl font-black font-poppins leading-tight uppercase tracking-tighter">
          Tu crecimiento,<br /> <span class="text-[#E63B11]">nuestra prioridad</span>
        </h3>
        
        <p class="text-gray-400 leading-relaxed text-base md:text-lg max-w-xl font-barlow text-center lg:text-justify mx-auto lg:mx-0">
          Un entorno diseñado para tu <span class="text-white font-semibold">bienestar y desarrollo</span>. Sabemos lo que valoras. En Qualtop te ofrecemos un espacio donde puedas <span class="text-white font-semibold">ser tú mismo</span> mientras te conviertes en el <span class="text-[#E63B11] font-bold">experto</span> que quieres ser: 
        </p>
      </div>

      <div class="relative group scroll-element-up flex justify-center items-center order-1 lg:order-2" style="transition-delay: 200ms;">
        <Image 
          src={atomoTech} 
          alt="Molécula Tech" 
          class="w-[70%] md:w-full max-w-[320px] md:max-w-[380px] hover:scale-105 transition-transform duration-700 mx-auto" 
        />
      </div>

    </div>
  </div>
</section>

<script is:inline>
  // Tu script de Parallax y Observer se mantiene igual, ya es funcional y responsivo.
  window.addEventListener('scroll', () => {
    const w1 = document.querySelector('.watermark-1');
    const w2 = document.querySelector('.watermark-2');
    if (!w1 || !w2) return;
    const scrollY = window.scrollY;
    w1.style.transform = `translateY(${scrollY * -0.05}px) rotate(${15 + scrollY * 0.02}deg)`;
    w2.style.transform = `translateY(${scrollY * -0.1}px) rotate(${(-12) + scrollY * -0.04}deg)`;
  });

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.querySelectorAll('.scroll-element-up').forEach(el => {
          el.classList.add('animate-reveal-up');
        });
      }
    });
  }, { threshold: 0.1 });

  const target = document.querySelector('.scroll-reveal-container');
  if (target) observer.observe(target);
</script>

<style is:global>
  @keyframes reveal-up {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-reveal-up { animation: reveal-up 1s ease-out forwards; }
  .scroll-element-up { opacity: 0; transform: translateY(30px); }
</style>